# Never cache the HTML entry point — it references hashed asset filenames
# that change on every build. Caching it causes white pages after deploys.
/index.html
  Cache-Control: no-store, no-cache, must-revalidate

/*
  Cache-Control: no-store, no-cache, must-revalidate

# JS and CSS assets have hashed filenames — safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable
